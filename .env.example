# Copy to .env. EXPO_PUBLIC_* vars are embedded in the bundle (not secret).
# Local dev on a phone: use your computer's LAN IP (e.g. http://192.168.1.20:4000).
# Production: your deployed backend URL (e.g. https://flowiix-pos-server.onrender.com).
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_API_KEY=<same value as server API_KEY>
